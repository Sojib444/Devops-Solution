{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "Jwt": {
    "Key": "SuperSecretKeyForDevOpsSolution2024!",
    "Issuer": "DevOpsSolution",
    "Audience": "DevOpsSolutionGateway"
  },
  "ReverseProxy": {
    "Routes": {
      "users-api": {
        "ClusterId": "users-cluster",
        "Match": { "Path": "/api/users/{**catch-all}" },
        "AuthorizationPolicy": "AuthenticatedUser"
      },
      "orders-api": {
        "ClusterId": "orders-cluster",
        "Match": { "Path": "/api/orders/{**catch-all}" },
        "AuthorizationPolicy": "AuthenticatedUser"
      },
      "inventory-api": {
        "ClusterId": "inventory-cluster",
        "Match": { "Path": "/api/products/{**catch-all}" },
        "AuthorizationPolicy": "AuthenticatedUser"
      },
      "users-swagger": {
        "ClusterId": "users-cluster",
        "Match": { "Path": "/users/swagger/{**catch-all}" },
        "Transforms": [ { "PathRemovePrefix": "/users" } ]
      },
      "orders-swagger": {
        "ClusterId": "orders-cluster",
        "Match": { "Path": "/orders/swagger/{**catch-all}" },
        "Transforms": [ { "PathRemovePrefix": "/orders" } ]
      },
      "inventory-swagger": {
        "ClusterId": "inventory-cluster",
        "Match": { "Path": "/inventory/swagger/{**catch-all}" },
        "Transforms": [ { "PathRemovePrefix": "/inventory" } ]
      }
    },
    "Clusters": {
      "users-cluster": {
        "LoadBalancingPolicy": "RoundRobin",
        "HealthCheck": {
          "Active": {
            "Enabled": true,
            "Interval": "00:00:10",
            "Timeout": "00:00:05",
            "Policy": "ConsecutiveFailures",
            "Path": "/health"
          },
          "Passive": {
            "Enabled": true,
            "Policy": "TransportFailureRate",
            "ReactivationPeriod": "00:00:30"
          }
        },
        "Destinations": {
          "destination1": { "Address": "http://localhost:5004/" }
        }
      },
      "orders-cluster": {
        "LoadBalancingPolicy": "RoundRobin",
        "HealthCheck": {
          "Active": {
            "Enabled": true,
            "Interval": "00:00:10",
            "Timeout": "00:00:05",
            "Policy": "ConsecutiveFailures",
            "Path": "/health"
          },
          "Passive": {
            "Enabled": true,
            "Policy": "TransportFailureRate",
            "ReactivationPeriod": "00:00:30"
          }
        },
        "Destinations": {
          "destination1": { "Address": "http://localhost:5001/" }
        }
      },
      "inventory-cluster": {
        "LoadBalancingPolicy": "RoundRobin",
        "HealthCheck": {
          "Active": {
            "Enabled": true,
            "Interval": "00:00:10",
            "Timeout": "00:00:05",
            "Policy": "ConsecutiveFailures",
            "Path": "/health"
          },
          "Passive": {
            "Enabled": true,
            "Policy": "TransportFailureRate",
            "ReactivationPeriod": "00:00:30"
          }
        },
        "Destinations": {
          "destination1": { "Address": "http://localhost:5002/" }
        }
      }
    }
  },
  "AllowedHosts": "*"
}
